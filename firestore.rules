// Firestore Security Rules for NutriFit
// =====================================
// Copy-paste these rules into Firebase Console → Firestore → Rules → Publish.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──────────────────────────────────────
    // Anyone authenticated can read their own doc.
    // Doctors can read their patients' docs.
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ── Plans collection ──────────────────────────────────────
    // Users can read their own plans.
    // Doctors can read/write plans for their patients.
    match /plans/{planId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
      );
    }

    // ── Logs collection (workout tracking) ────────────────────
    // Users can read/write their own logs.
    // Doctors can read their patients' logs.
    match /logs/{logId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
      );
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // ── Health Profiles collection ────────────────────────────
    // Users can read/write their own profile.
    match /health_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
